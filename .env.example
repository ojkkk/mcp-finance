# ═══════════════════════════════════════════
# mcp-finance 环境变量配置
# ═══════════════════════════════════════════
# 
# 使用方法：
#   1. 复制本文件为 .env（不要提交到 Git！）
#      cp .env.example .env
#   2. 填入你自己的 Token
#   3. 启动程序时会自动读取 .env 文件
#
# ═══════════════════════════════════════════

# ── Tushare (财务数据: PE/PB/ROE/季报) ──
# 注册地址: https://tushare.pro
# 免费注册，获取 token 后填入下方
# 不设置也可以用，系统会自动降级到 AKShare/easy-tdx
TUSHARE_TOKEN=your_tushare_token_here

# ── 可选：数据超时设置（秒）──
# MCP_FINANCE_TIMEOUT=15

# ── 可选：日志级别 ──
# LOG_LEVEL=INFO
# LOG_FORMAT=text
